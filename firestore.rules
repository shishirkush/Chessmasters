rules_version = '2';

// SECURITY MODEL FOR SLICE 1
// -------------------------------------------------------------
// The whole integrity of the game rests here: clients may READ
// games but may NEVER write to them. All writes happen through
// Cloud Functions using the Admin SDK, which BYPASSES these rules.
// So even a fully modified Flutter app cannot fake a move, flip a
// turn, or declare itself the winner — it has no write path.
//
// When CP / money is added later, the same principle protects
// balances: ledgers will be function-write-only too.

service cloud.firestore {
  match /databases/{database}/documents {

    match /games/{gameId} {
      // A signed-in user may read a game if they are one of its players,
      // OR if it is still waiting (so quick-match can discover open games).
      allow read: if request.auth != null
                  && (
                       resource.data.status == 'waiting'
                       || request.auth.uid in resource.data.players
                     );

      // No client writes, ever. Cloud Functions (Admin SDK) handle all writes.
      allow write: if false;
    }

    // SLICE 2b: user profiles.
    // Any signed-in user may READ any profile — needed to show opponent
    // names, avatars, and (later) leaderboards. Profiles are created and
    // updated ONLY by Cloud Functions (the onUserCreate trigger and the
    // rating-update logic), so clients have no write path. This keeps
    // rating a server-owned, untamperable, skill-only quantity.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // SLICE 2c: circles (social spaces).
    // Readable by any signed-in user (needed for search/browse in 2d and to
    // view membership). Created/modified/deleted ONLY by Cloud Functions
    // (createCircle / leaveCircle / deleteCircle), so clients can't forge
    // membership, seize ownership, or tamper with the member list.
    match /circles/{circleId} {
      allow read: if request.auth != null;
      allow write: if false;

      // SLICE 2d: join requests (subcollection).
      // A signed-in user may read join requests on a circle if they are the
      // circle's owner (to review pending requests) OR the request is their
      // own (to see their pending status). All writes go through Cloud
      // Functions (requestJoin / approveJoin / rejectJoin / cancelJoinRequest).
      match /joinRequests/{applicantId} {
        allow read: if request.auth != null
                    && (
                         request.auth.uid == applicantId
                         || request.auth.uid == get(
                              /databases/$(database)/documents/circles/$(circleId)
                            ).data.ownerId
                       );
        allow write: if false;
      }
    }

    // SLICE 3a: the CP ledger (append-only, server-owned).
    // A user may READ ONLY their own ledger entries (their financial record —
    // used by the client to compute their live CP balance by summing). They
    // can never read another user's entries. NO client writes, ever: all CP
    // movement (grants, stakes, pots, rake) is written by Cloud Functions via
    // the Admin SDK, which bypasses these rules. Entries are append-only and
    // are never updated or deleted, by server convention — a correction is a
    // new compensating entry, not an edit.
    match /ledger/{entryId} {
      allow read: if request.auth != null
                  && resource.data.account == request.auth.uid;
      allow write: if false;
    }

    // SLICE 3c: peer stakes (server-owned).
    // A signed-in user may READ a stake only if they are a party to it (the
    // issuer or the challenged opponent) — so each side can see pending offers
    // and the linked game. NO client writes: propose/accept/cancel/decline and
    // settlement all run in Cloud Functions via the Admin SDK. This keeps CP
    // escrow and pot settlement entirely server-authoritative.
    match /stakes/{stakeId} {
      allow read: if request.auth != null
                  && (
                       request.auth.uid == resource.data.issuerId
                       || request.auth.uid == resource.data.opponentId
                     );
      allow write: if false;
    }

    // SLICE 4: conquest (server-owned).
    // A signed-in user may READ a conquest if they are the challenger OR a
    // current member of the target circle (so defenders and the owner can see
    // the breach/Gauntlet they're involved in). Membership is checked with a
    // cross-doc get() on the circle — the same pattern the joinRequests rule
    // above already uses. NO client writes: initiateBreach / acceptBreachDefense
    // / nomination / settlement all run in Cloud Functions via the Admin SDK,
    // keeping the whole conquest state machine server-authoritative.
    match /conquests/{conquestId} {
      allow read: if request.auth != null
                  && (
                       request.auth.uid == resource.data.challengerId
                       || request.auth.uid in get(
                            /databases/$(database)/documents/circles/$(resource.data.circleId)
                          ).data.members
                     );
      allow write: if false;
    }

    // SLICE 4: conquest cooldowns (server-only).
    // Per-attacker-per-circle weekly breach cooldown timestamps, written and
    // read ONLY by Cloud Functions (initiateBreach checks/sets them in-tx).
    // Clients never need these, so deny all client access — same as gameCounts.
    match /conquestCooldowns/{cdId} {
      allow read, write: if false;
    }

    // SLICE 3d: daily game counters (server-only).
    // Written by Cloud Functions to enforce the quick-match and same-opponent
    // daily caps. Clients never need to read these directly (the function
    // returns a clear error when a cap is hit), so deny all client access.
    match /gameCounts/{docId} {
      allow read, write: if false;
    }
  }
}
